# Python interpreter path (must have google-cloud-speech, google-cloud-texttospeech, pyaudio installed)
PYTHON_PATH=/path/to/your/venv/bin/python3

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
#OPENAI_MODEL=gpt-4o
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_ANALYSIS=gpt-4o

# Google Cloud credentials (required for speech-to-text and text-to-speech)
# Download a service account JSON key from https://console.cloud.google.com/iam-admin/serviceaccounts
# Save it as key-service-account-google.json in the project root
GOOGLE_APPLICATION_CREDENTIALS=key-service-account-google.json

# Picovoice Porcupine wake word detection (required for voice activation)
# Get a free access key from https://console.picovoice.ai/
# Save it in key-porcupine.json as: { "access_key": "your-key-here" }
PORCUPINE_ACCESS_KEY=key-porcupine.json

# DotPad serial port (macOS: /dev/cu.usbserial-XXXX, Linux: /dev/ttyUSB0)
SERIAL_PORT_PATH=/dev/cu.usbserial-XXXX

# Remote MQTT broker (HiveMQ Cloud or equivalent)
# Used by the remote MQTTReceiver instance when isRemote is enabled in the Inspector
MQTT_REMOTE_HOST=your-cluster-id.s1.eu.hivemq.cloud
MQTT_REMOTE_PORT=8883
MQTT_REMOTE_USERNAME=your-mqtt-username
MQTT_REMOTE_PASSWORD=your-mqtt-password
